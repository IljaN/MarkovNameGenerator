<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>12.0</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>

    <!-- Package Information -->
    <PackageId>MarkovNameGenerator</PackageId>
    <Version>1.0.0</Version>
    <Authors>Ported from Haxe library by Tw1ddle</Authors>
    <Description>A procedural name generator using Markov chains with Katz back-off and Dirichlet prior smoothing</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/Tw1ddle/markov-namegen-lib</RepositoryUrl>
    <PackageTags>markov;name-generator;procedural;random</PackageTags>
  </PropertyGroup>

</Project>
